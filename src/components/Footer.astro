---
// Footer.astro - Site footer with copyright
const year = new Date().getFullYear();
---
<footer class="w-full border-t border-[var(--border,#d5c4a1)] dark:border-[var(--border-dark,#504945)] mt-auto">
  <div class="max-w-3xl mx-auto px-4 py-6 text-center text-sm text-[var(--muted,#7c6f64)]">
    &copy; {year} Nep
  </div>
</footer>
