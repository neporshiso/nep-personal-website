---
import { getCollection, render } from 'astro:content';
import { Icon } from 'astro-icon/components';
import BaseLayout from '../layouts/BaseLayout.astro';

const bioEntries = await getCollection('bio');
const bio = bioEntries[0];
const { Content } = bio ? await render(bio) : { Content: null };

const socialEntries = await getCollection('social');
const social = socialEntries[0];
const email = social?.data.email ?? '';
const github = social?.data.github ?? '';
const linkedin = social?.data.linkedin ?? '';
---
<BaseLayout title="About — Nep" siteTitle="about nep">
  <h1 class="sr-only">about nep</h1>

  {Content ? (
    <div class="prose">
      <Content />
    </div>
  ) : (
    <p class="text-base text-[var(--muted,#7c6f64)]">Bio content coming soon.</p>
  )}

  <div class="flex items-center gap-6 mt-8">
    {github && (
      <a
        href={github}
        target="_blank"
        rel="noopener noreferrer"
        class="text-[var(--muted,#7c6f64)] hover:text-[var(--text)] transition-colors flex items-center gap-2"
      >
        <Icon name="ph:github-logo" class="w-5 h-5" aria-hidden="true" />
        <span class="text-sm">GitHub</span>
      </a>
    )}
    {linkedin && (
      <a
        href={linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="text-[var(--muted,#7c6f64)] hover:text-[var(--text)] transition-colors flex items-center gap-2"
      >
        <Icon name="ph:linkedin-logo" class="w-5 h-5" aria-hidden="true" />
        <span class="text-sm">LinkedIn</span>
      </a>
    )}
    {email && (
      <a
        href={`mailto:${email}`}
        class="text-[var(--muted,#7c6f64)] hover:text-[var(--text)] transition-colors flex items-center gap-2"
      >
        <Icon name="ph:envelope-simple" class="w-5 h-5" aria-hidden="true" />
        <span class="text-sm">Email</span>
      </a>
    )}
  </div>
</BaseLayout>
