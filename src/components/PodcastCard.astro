---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  name: string;
  link: string;
  coverImage?: ImageMetadata;
  category?: string;
}

const { name, link, coverImage, category } = Astro.props;
---

<a href={link} target="_blank" rel="noopener noreferrer" class="block hover:opacity-80 no-underline">
  {coverImage ? (
    <Image
      src={coverImage}
      alt={name}
      width={200}
      height={200}
      loading="lazy"
      class="w-full aspect-square rounded-md object-cover"
    />
  ) : (
    <div class="w-full aspect-square rounded-md bg-[var(--border,#d5c4a1)] dark:bg-[var(--border-dark,#504945)]"></div>
  )}
  <div class="pt-2">
    <p class="text-sm font-semibold text-[var(--text)] line-clamp-2">{name}</p>
  </div>
</a>
